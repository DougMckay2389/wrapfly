# Copy to .env.local and fill in values.
#
# PUBLIC (safe to expose to the browser):
NEXT_PUBLIC_SUPABASE_URL=https://mtocuyoydedhmjzvocra.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sHQJ1UvMUetHM2xRM800eQ_gZC-osDw
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Square (https://developer.squareup.com/apps) — sandbox first.
NEXT_PUBLIC_SQUARE_APPLICATION_ID=sandbox-sq0idb-...
NEXT_PUBLIC_SQUARE_LOCATION_ID=L...
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# SECRETS (server-only, never exposed):
# Supabase service role key — Settings → API → "service_role" (DO NOT commit).
SUPABASE_SERVICE_ROLE_KEY=

# Square access token (sandbox or production). Server-side only.
SQUARE_ACCESS_TOKEN=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# Resend (https://resend.com) — transactional email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Wrapfly <orders@wrapfly.com>

# Optional: get an internal email each time a new order lands.
ADMIN_NOTIFY_EMAIL=
