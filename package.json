    "import:grimco:dry": "tsx scripts/grimco/import.ts --dry-run",
    "import:grimco:csv": "tsx scripts/grimco/import-csv.ts",
    "import:grimco:summary": "tsx scripts/grimco/import-csv-summary.ts",
    "mirror:images": "tsx scripts/grimco/mirror-images-rendered.ts",
    "mirror:images:fast": "tsx scripts/grimco/mirror-images.ts",
    "mirror:categories": "tsx scripts/grimco/mirror-category-images.ts"
  },
  "dependencies": {
