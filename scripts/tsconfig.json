{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "lib": ["es2022", "dom"],
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["**/output/**", "**/.profile/**"]
}
